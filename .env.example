VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SENTRY_DSN=
VITE_LOG_LEVEL=warn
VITE_STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
VITE_STRIPE_PRO_PRICE_ID=price_your-pro-plan-price-id

# Edge Function Secrets (Do not expose to Vite/frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# AI via OpenRouter gateway. Region-safe models ONLY (no OpenAI / Google / Anthropic).
AI_API_KEY=your-openrouter-key
AI_MODEL_NAME=moonshotai/kimi-k2.6
FALLBACK_MODEL_NAME=deepseek/deepseek-chat
VISION_MODEL_NAME=qwen/qwen3-vl-235b-a22b-instruct
FALLBACK_VISION_MODEL_NAME=qwen/qwen2.5-vl-72b-instruct
ELEVENLABS_API_KEY=your-elevenlabs-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-plan-price-id

NODE_ENV=development
